# ── NETLIFY ENVIRONMENT VARIABLES ──────────────────────────────
# Set these in: netlify.com → Site config → Environment variables

BACKEND_URL=https://videodl-backend.onrender.com   # ← your actual Render URL
API_KEY=                                            # ← copy from Render dashboard

# ── NETLIFY BUILD-TIME VARIABLES ───────────────────────────────
# Also set in Netlify env vars (VITE_ prefix = baked into browser JS)

VITE_API_BASE=/api
VITE_BACKEND_DIRECT=https://videodl-backend.onrender.com  # ← same Render URL

# ── RENDER.COM ENVIRONMENT VARIABLES ───────────────────────────
# Set these in: render.com → your service → Environment

API_KEY=              # auto-generated by Render — copy to Netlify
JWT_SECRET=           # auto-generated by Render — do NOT share
FRONTEND_URL=https://your-site.netlify.app   # ← your actual Netlify URL
